          "year": "{currentYear}.",
          "reason": "I was brought in because of {patientReason}."
        }
      },
      {
        "id": "verbal_v4",
        "correctScore": 4,
        "responses": {
          "name": "{wrongFirstName} {patientSurname}.",
          "place": "{wrongPlace}.",
          "year": "{wrongYear}.",
          "reason": "{confusedReason}."
        }
      },
      {
        "id": "verbal_v3",
        "correctScore": 3,
        "responses": {
